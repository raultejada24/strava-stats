# ─── Intervals.icu ────────────────────────────────────────────────────────────
# Athlete ID: visible en la URL → intervals.icu/athlete/i123456 → "i123456"
INTERVALS_ATHLETE_ID=i123456

# API Key: intervals.icu → perfil → Settings → "API Access" → copiar la clave
INTERVALS_API_KEY=tu_api_key_aqui

# ─── Strava Export (opcional, solo para tracks GPS) ───────────────────────────
# Ruta al .zip del export de Strava. Solo necesario si quieres mapas de ruta.
# STRAVA_EXPORT_PATH=/ruta/a/tu/export_12345.zip
